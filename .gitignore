# --------------------------------------------------------
#  Nest Project .gitignore
#  Covers Vite + React + Storybook + Docker + Local data
# --------------------------------------------------------

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
pnpm-lock.yaml
yarn.lock

# Build output
dist/
build/
.out/
.vite/
*.local

# Storybook
storybook-static/
.out/
.cache/
*.storybook-cache/
*.sb-cache/

# TypeScript
*.tsbuildinfo

# Logs
logs
*.log
*.log.*
logs/*
debug.log*
error.log*

# Local environment configs
.env
.env.*
!.env.example

# IDE/editor junk
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# OS stuff
ehthumbs.db
Icon?
__MACOSX/

# Docker
*.pid
*.seed
docker/*.log
docker/data/
docker/volumes/

# Data and Config
data/
config.local.json
*.bak
*.tmp

# Testing
coverage/
*.test.js.map
*.spec.js.map
*.coverage

# Storybook build cache (for performance)
apps/**/.storybook/out/
apps/**/.storybook-static/
apps/**/.storybook-cache/

# Misc
*.iml
*.orig
*.rej
*.diff
*.patch
*.bak
*.tmp
