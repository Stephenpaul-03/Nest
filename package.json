{
  "name": "nest",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:accounts": "cd apps/accounts && npm run dev",
    "dev:events": "cd apps/events && npm run dev",
    "dev:vaults": "cd apps/vaults && npm run dev",
    "dev:core": "cd apps/core && npm run dev",

    "dev": "npm-run-all --parallel dev:accounts dev:events dev:vaults dev:core"
  }
}
